# Toolkit assumed by AGENTS.md's tool preferences (README step 3).
# Install: brew bundle        Audit an existing machine: brew bundle check --verbose
brew "fd"           # finding FILES
brew "ripgrep"      # finding TEXT (rg)
brew "ast-grep"     # finding/rewriting CODE STRUCTURE
brew "sd"           # replacing text
brew "fzf"          # interactive selection
brew "jq"           # JSON
brew "jc"           # classic command output -> JSON
brew "yq"           # YAML / XML (mikefarah Go build)
brew "taplo"        # TOML
brew "difftastic"   # human-readable diffs (difft)
brew "scc"          # LOC / code stats
brew "hyperfine"    # benchmarking
brew "shellcheck"   # shell script linting
brew "actionlint"   # GitHub Actions workflow linting
